# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# JWT – mit `openssl rand -hex 32` generieren
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Trainer-Konto (einziger Login; Teilnehmer treten per Kurs-Code bei)
ADMIN_EMAIL=trainer@firma.de
ADMIN_PASSWORD=change-me-strong-password

# Erlaubte Frontend-Origins (CORS), kommasepariert. In Prod auf die echte Domain
# setzen; nur nötig, wenn Frontend und Backend unter verschiedenen Origins laufen.
ALLOWED_ORIGINS=http://localhost:5173

# Ansible-Lab: Pfad zur gemeinsamen Warteschlange (Volume, das Backend und
# Runner teilen). Mit /queue einschalten, LEER LASSEN schaltet das Lab ab —
# dann antwortet die API mit 503 und der Kurs laeuft unveraendert weiter.
# Es gibt bewusst kein Token mehr: Der Runner hat gar kein Netzwerk
# (network_mode: none), die Grenze ist das Volume. Siehe docs/lab-sicherheit.md.
LAB_QUEUE_DIR=
