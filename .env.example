# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# JWT – mit `openssl rand -hex 32` generieren
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Trainer-Konto (einziger Login; Teilnehmer treten per Kurs-Code bei)
ADMIN_EMAIL=trainer@firma.de
ADMIN_PASSWORD=change-me-strong-password

# Erlaubte Frontend-Origins (CORS), kommasepariert. In Prod auf die echte Domain
# setzen; nur nötig, wenn Frontend und Backend unter verschiedenen Origins laufen.
ALLOWED_ORIGINS=http://localhost:5173

# Ansible-Lab-Runner – führt Teilnehmer-Playbooks wirklich aus (siehe
# docs/lab-sicherheit.md, unbedingt vor dem Aktivieren lesen).
# BEIDE Werte leer lassen = Lab AUS: die API antwortet mit 503, das Widget
# zeigt einen Hinweis, der Kurs bleibt ganz normal nutzbar.
# Interne Compose-Adresse des Runner-Dienstes (kein Host-Port, von außen nicht
# erreichbar); zum Aktivieren auf http://runner:8080 setzen.
LAB_RUNNER_URL=
# Mit `openssl rand -hex 32` erzeugen. Derselbe Wert geht 1:1 als RUNNER_TOKEN
# an den Runner-Container (siehe docker-compose.yml) – beide müssen exakt
# übereinstimmen, sonst lehnt der Runner jede Anfrage ab.
LAB_RUNNER_TOKEN=
