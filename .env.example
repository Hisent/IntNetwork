# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# JWT – mit `openssl rand -hex 32` generieren
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Trainer-Konto (einziger Login; Teilnehmer treten per Kurs-Code bei)
ADMIN_EMAIL=trainer@firma.de
ADMIN_PASSWORD=change-me-strong-password

# Erlaubte Frontend-Origins (CORS), kommasepariert. In Prod auf die echte Domain
# setzen; nur nötig, wenn Frontend und Backend unter verschiedenen Origins laufen.
ALLOWED_ORIGINS=http://localhost:5173

# Ansible-Lab: Pfad zur gemeinsamen Warteschlange (Volume, das Backend und
# Runner teilen). Mit /queue einschalten, LEER LASSEN schaltet das Lab ab —
# dann antwortet die API mit 503 und der Kurs laeuft unveraendert weiter.
# Es gibt bewusst kein Token mehr: Der Runner hat gar kein Netzwerk
# (network_mode: none), die Grenze ist das Volume. Siehe docs/lab-sicherheit.md.
LAB_QUEUE_DIR=

# Welche Auftragsarten das Lab ausfuehren darf. Beide Zeilen muessen
# uebereinstimmen — es gibt keinen Netzweg zwischen Backend und Runner, die
# Werte werden also NICHT automatisch abgeglichen. Moeglich: ansible, openssl, git.
# Nur "openssl" (ohne "ansible") heisst: der Runner fuehrt keinen frei
# geschriebenen Code mehr aus — weniger Angriffsflaeche, siehe docs/lab-sicherheit.md.
LAB_KINDS=ansible
RUNNER_KINDS=ansible

# Passkey-Anmeldung fuer Trainer (WebAuthn). BEIDE Werte setzen oder beide leer
# lassen — leer heisst: Funktion aus, der Anmeldeknopf erscheint gar nicht erst.
# Das Passwort bleibt in jedem Fall nutzbar.
#
#   WEBAUTHN_RP_ID   = nur der Hostname der Adresse, die im BROWSER steht.
#                      Ohne Schema, ohne Port, ohne Pfad, ohne Schraegstrich.
#   WEBAUTHN_ORIGIN  = derselbe Ort als vollstaendiger Ursprung, also mit
#                      Schema und (nur falls abweichend) mit Port. Kein
#                      abschliessender Schraegstrich.
#
# Beispiele:
#   Browser zeigt https://intlab.firma.de/trainer
#     WEBAUTHN_RP_ID=intlab.firma.de
#     WEBAUTHN_ORIGIN=https://intlab.firma.de
#   Browser zeigt https://lab.firma.de:8443
#     WEBAUTHN_RP_ID=lab.firma.de          <- niemals mit Port
#     WEBAUTHN_ORIGIN=https://lab.firma.de:8443
#   Lokale Entwicklung ueber den Vite-Server
#     WEBAUTHN_RP_ID=localhost
#     WEBAUTHN_ORIGIN=http://localhost:5173
#
# Stolperstellen: Gemeint ist die oeffentliche Adresse, nicht der Containername
# hinter dem Proxy. Eine reine IP-Adresse funktioniert NICHT (WebAuthn verlangt
# einen Domainnamen). Ausser auf localhost ist HTTPS Pflicht. Und: Ein spaeterer
# Domainwechsel macht alle registrierten Passkeys unbrauchbar — dann muss jeder
# Trainer seinen Passkey neu anlegen.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=
