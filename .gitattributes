# Reproduzierbare Zeilenenden: Quellcode und Konfiguration liegen im Repository
# stets mit LF vor, unabhaengig davon ob lokal unter Windows entwickelt wird.
* text=auto
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
Dockerfile text eol=lf
requirements*.txt text eol=lf
.gitignore text eol=lf
